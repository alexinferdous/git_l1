# -------------------------------------------------------
# Wealthsimple credentials
# -------------------------------------------------------
WS_EMAIL=your_email@example.com
WS_PASSWORD=your_password

# Base32 TOTP secret from your 2FA setup
# (the secret key you scanned/entered when setting up Google Authenticator,
#  NOT the 6-digit rotating code)
# Leave blank to be prompted interactively instead.
WS_OTP_SECRET=

# -------------------------------------------------------
# Safety: set to "false" ONLY when you are ready for live trading
# -------------------------------------------------------
WS_PAPER_TRADE=true

# -------------------------------------------------------
# Strategy settings
# -------------------------------------------------------
# Comma-separated US stock tickers to watch
TICKERS=AAPL,MSFT,NVDA,AMZN,GOOGL

# Moving average windows (days)
SHORT_MA_WINDOW=50
LONG_MA_WINDOW=200

# -------------------------------------------------------
# Risk management
# -------------------------------------------------------
# Maximum USD value to spend per BUY order
MAX_POSITION_USD=500

# Maximum number of orders (buy + sell) per calendar day
MAX_DAILY_TRADES=5

# -------------------------------------------------------
# Scheduling
# -------------------------------------------------------
# How often (minutes) the bot re-evaluates signals
# Markets are open 09:30–16:00 ET Mon–Fri; 60 min is a sensible default.
CHECK_INTERVAL_MIN=60
